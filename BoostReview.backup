  });
  const [showWidgetCode, setShowWidgetCode] = useState(null);
  const [customerEmail, setCustomerEmail] = useState('');
  const [customerName, setCustomerName] = useState('');
  const [customerPhone, setCustomerPhone] = useState('');
  const [searchTerm, setSearchTerm] = useState('');
  const [selectedCustomers, setSelectedCustomers] = useState([]);
  const [showBulkSuccess, setShowBulkSuccess] = useState(false);
  const [businessDescription, setBusinessDescription] = useState('We are a family-owned business dedicated to providing excellent service to our customers.');
  const [responseStyle, setResponseStyle] = useState('professional');
  
  const [customers, setCustomers] = useState([
    { id: 1, name: 'Sarah Johnson', email: 'sarah.j@email.com', phone: '(555) 123-4567', addedDate: '2025-10-10', status: 'active' },
    { id: 2, name: 'Michael Chen', email: 'mchen@email.com', phone: '(555) 234-5678', addedDate: '2025-10-12', status: 'active' },
    { id: 3, name: 'Emily Rodriguez', email: 'emily.r@email.com', phone: '(555) 345-6789', addedDate: '2025-10-13', status: 'active' },
    { id: 4, name: 'James Williams', email: 'jwilliams@email.com', phone: '(555) 456-7890', addedDate: '2025-10-14', status: 'active' },
    { id: 5, name: 'Lisa Anderson', email: 'landerson@email.com', phone: '(555) 567-8901', addedDate: '2025-10-14', status: 'active' },
  ]);
  
  const [sentRequests, setSentRequests] = useState([
    { id: 1001, name: 'John Smith', email: 'john@email.com', phone: '(555) 123-4567', sentAt: '2025-10-14 10:30 AM', status: 'Reviewed', reviewLink: true, method: 'SMS' },
    { id: 1002, name: 'Mary Davis', email: 'mary@email.com', phone: '(555) 234-5678', sentAt: '2025-10-14 11:45 AM', status: 'Opened', reviewLink: false, method: 'Email' },
    { id: 1003, name: 'Robert Brown', email: 'robert@email.com', phone: '(555) 345-6789', sentAt: '2025-10-13 3:20 PM', status: 'Sent', reviewLink: false, method: 'SMS' },
  ]);

  const [reviews, setReviews] = useState([
    {
      id: 1,
      customerName: 'Jessica Martinez',
      rating: 5,
      text: 'Absolutely amazing service! The team went above and beyond to help me. I was impressed by their attention to detail and professionalism. Will definitely be back!',
      date: '2025-10-15',
      platform: 'Google',
      sentiment: 'positive',
      response: null,
      responded: false,
      keywords: ['amazing', 'professional', 'attention to detail'],
      emotions: ['joy', 'satisfaction']
    },
    {
      id: 2,
      customerName: 'David Thompson',
      rating: 2,
      text: 'Disappointed with the service. Had to wait over 30 minutes and the staff seemed overwhelmed. The quality wasn\'t what I expected based on the reviews.',
      date: '2025-10-14',
      platform: 'Yelp',
      sentiment: 'negative',
      response: null,
      responded: false,
      keywords: ['disappointed', 'wait', 'overwhelmed'],
      emotions: ['frustration', 'disappointment']
    },
    {
      id: 3,
      customerName: 'Amanda Lee',
      rating: 4,
      text: 'Good experience overall. The service was solid and the team was friendly. Only minor issue was the wait time, but everything else was great.',
      date: '2025-10-13',
      platform: 'Facebook',
      sentiment: 'positive',
