    },
    {
      id: 5,
      customerName: 'Michelle Chang',
      rating: 5,
      text: 'Best experience I\'ve had! Everything was perfect from start to finish. The staff was knowledgeable and friendly. Highly recommend!',
      date: '2025-10-11',
      platform: 'Trustpilot',
      sentiment: 'positive',
      response: null,
      responded: false,
