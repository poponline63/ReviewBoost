      responded: false,
      keywords: ['good', 'friendly', 'solid'],
      emotions: ['satisfaction']
    },
    {
      id: 4,
      customerName: 'Robert Kim',
      rating: 1,
      text: 'Terrible experience. The product didn\'t work as advertised and customer service was unhelpful. Would not recommend.',
      date: '2025-10-12',
      platform: 'Google',
      sentiment: 'negative',
      response: null,
      responded: false,
